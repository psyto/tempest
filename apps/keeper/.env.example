# Tempest Keeper Configuration

# RPC endpoint (required)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Keeper wallet private key (required, with 0x prefix)
PRIVATE_KEY=0x...

# Deployed TempestHook contract address (required)
HOOK_ADDRESS=0x...

# Comma-separated pool IDs to monitor (required)
POOL_IDS=0xabc...,0xdef...

# Chain ID (default: 1 for mainnet, 11155111 for Sepolia)
CHAIN_ID=11155111

# Polling interval in milliseconds (default: 300000 = 5 minutes)
POLL_INTERVAL_MS=300000

# Maximum gas price in gwei before skipping updates (default: 50)
# Note: the keeper will override this limit when pools approach staleness (>80% of staleFeeThreshold)
MAX_GAS_GWEI=50
